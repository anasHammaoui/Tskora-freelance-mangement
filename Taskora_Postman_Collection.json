    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"E-Commerce Platform Redesign\",\n  \"description\": \"Full redesign and development of the client e-commerce website with modern UI/UX.\",\n  \"budget\": 15000.00,\n  \"status\": \"EN_COURS\",\n  \"startDate\": \"2026-03-01\",\n  \"endDate\": \"2026-06-30\",\n  \"clientId\": 1,\n  \"userId\": 1\n}"
            }
          }
        },
        {
          "name": "Get Project By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "description": "Get all projects, optionally filtered by status (EN_COURS, TERMINE, EN_ATTENTE, ANNULE).",
            "url": {
              "raw": "{{baseUrl}}/projects?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "page", "value": "0" },
