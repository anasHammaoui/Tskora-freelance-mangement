  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "admin", "type": "string" },
      { "key": "password", "value": "admin", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ayoub Hammaoui\",\n  \"email\": \"ayoub.hammaoui@example.com\",\n  \"password\": \"securePassword123\",\n  \"role\": \"FREELANCER\"\n}"
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/1", "host": ["{{baseUrl}}"], "path": ["users", "1"] }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get All Freelancers",
          "request": {
            "method": "GET",
            "description": "Get all freelancers, optionally filtered by status (ACTIVE, BANNED) or searched by name. Admin only.",
            "url": {
              "raw": "{{baseUrl}}/users/freelancers?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users", "freelancers"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "ACTIVE", "disabled": true },
                { "key": "search", "value": "Ayoub", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/1", "host": ["{{baseUrl}}"], "path": ["users", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ayoub Hammaoui Updated\",\n  \"email\": \"ayoub.updated@example.com\",\n  \"password\": \"newSecurePassword456\",\n  \"role\": \"FREELANCER\"\n}"
            }
          }
        },
        {
          "name": "Ban User",
          "request": {
            "method": "PATCH",
            "description": "Ban a user account. Admin only.",
            "url": { "raw": "{{baseUrl}}/users/1/ban", "host": ["{{baseUrl}}"], "path": ["users", "1", "ban"] }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "description": "Activate or reactivate a user account. Admin only.",
            "url": { "raw": "{{baseUrl}}/users/1/activate", "host": ["{{baseUrl}}"], "path": ["users", "1", "activate"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/1", "host": ["{{baseUrl}}"], "path": ["users", "1"] }
          }
        }
