    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Create a new invoice with automatic number generation and HT/TVA/TTC calculation.",
            "url": { "raw": "{{baseUrl}}/invoices", "host": ["{{baseUrl}}"], "path": ["invoices"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issueDate\": \"2026-03-04\",\n  \"dueDate\": \"2026-04-04\",\n  \"taxRate\": 20.00,\n  \"projectId\": 1,\n  \"userId\": 1,\n  \"lines\": [\n    {\n      \"description\": \"UI/UX Design - Homepage & Landing Pages\",\n      \"quantity\": 1,\n      \"unitPrice\": 3500.00\n    },\n    {\n      \"description\": \"Frontend Development\",\n      \"quantity\": 2,\n      \"unitPrice\": 2500.00\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Invoice By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/invoices/{{invoiceId}}", "host": ["{{baseUrl}}"], "path": ["invoices", "{{invoiceId}}"] }
          }
        },
        {
          "name": "Get All Invoices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/invoices?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Invoices By User",
          "request": {
            "method": "GET",
            "description": "Get invoices for a specific user. Filter by status: EN_ATTENTE, PAYEE, ANNULEE.",
            "url": {
              "raw": "{{baseUrl}}/invoices/user/{{userId}}?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "user", "{{userId}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "EN_ATTENTE", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Invoices By Project",
          "request": {
            "method": "GET",
            "description": "Get all invoices for a specific project.",
            "url": {
              "raw": "{{baseUrl}}/invoices/project/{{projectId}}?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "project", "{{projectId}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Mark Invoice As Paid",
          "request": {
            "method": "PATCH",
            "description": "Mark an invoice as paid (status → PAYEE). Required for revenue to appear in dashboard.",
            "url": { "raw": "{{baseUrl}}/invoices/{{invoiceId}}/pay", "host": ["{{baseUrl}}"], "path": ["invoices", "{{invoiceId}}", "pay"] }
          }
        },
        {
          "name": "Cancel Invoice",
          "request": {
            "method": "PATCH",
            "description": "Cancel an invoice (status → ANNULEE).",
            "url": { "raw": "{{baseUrl}}/invoices/{{invoiceId}}/cancel", "host": ["{{baseUrl}}"], "path": ["invoices", "{{invoiceId}}", "cancel"] }
          }
        },
        {
          "name": "Delete Invoice",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/invoices/{{invoiceId}}", "host": ["{{baseUrl}}"], "path": ["invoices", "{{invoiceId}}"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Freelancer Dashboard",
          "request": {
            "method": "GET",
            "description": "Returns: totalClients, activeProjects, pendingInvoices, currentMonthRevenue, last6MonthsRevenue (array ready for graph).",
            "url": { "raw": "{{baseUrl}}/dashboard/freelancer/{{userId}}", "host": ["{{baseUrl}}"], "path": ["dashboard", "freelancer", "{{userId}}"] }
          }
        },
        {
          "name": "Get Admin Dashboard",
          "request": {
            "method": "GET",
            "description": "Returns: freelancer stats, project stats, totalPlatformRevenue, last 12 months monthly revenue (array ready for graph).",
            "url": { "raw": "{{baseUrl}}/dashboard/admin", "host": ["{{baseUrl}}"], "path": ["dashboard", "admin"] }
          }
        },
        {
          "name": "Get Freelancer Revenue - Specific Month",
          "request": {
            "method": "GET",
            "description": "Day-by-day revenue breakdown for the given month. Returns totalRevenue + dailyRevenue array (31 entries). Perfect for a detailed monthly chart. Change year/month params as needed.",
            "url": {
              "raw": "{{baseUrl}}/dashboard/freelancer/{{userId}}/revenue?year=2026&month=3",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "freelancer", "{{userId}}", "revenue"],
              "query": [
                { "key": "year", "value": "2026" },
                { "key": "month", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "Get Admin Revenue - Specific Month",
          "request": {
            "method": "GET",
            "description": "Platform-wide day-by-day revenue breakdown for the given month. Returns totalRevenue + dailyRevenue array. Change year/month params as needed.",
            "url": {
              "raw": "{{baseUrl}}/dashboard/admin/revenue?year=2026&month=3",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "admin", "revenue"],
              "query": [
                { "key": "year", "value": "2026" },
                { "key": "month", "value": "3" }
              ]
            }
          }
        }
      ]
    }
  ]
