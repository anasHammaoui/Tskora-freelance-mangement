{
  "info": {
    "_postman_id": "taskora-collection-v3",
    "name": "Taskora API",
    "description": "Complete REST API collection for Taskora backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "admin", "type": "string" },
      { "key": "password", "value": "admin", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080/api", "type": "string" },
    { "key": "userId",     "value": "1", "type": "string" },
    { "key": "clientId",   "value": "1", "type": "string" },
    { "key": "projectId",  "value": "1", "type": "string" },
    { "key": "taskId",     "value": "1", "type": "string" },
    { "key": "invoiceId",  "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ayoub Hammaoui\",\n  \"email\": \"ayoub.hammaoui@example.com\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_FREELANCER\"\n}"
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get All Freelancers",
          "request": {
            "method": "GET",
            "description": "Get all freelancers, optionally filtered by status (ACTIVE, BANNED) or searched by name. Admin only.",
            "url": {
              "raw": "{{baseUrl}}/users/freelancers?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users", "freelancers"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "ACTIVE", "disabled": true },
                { "key": "search", "value": "Ayoub", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ayoub Hammaoui Updated\",\n  \"email\": \"ayoub.updated@example.com\",\n  \"password\": \"newSecurePassword456\",\n  \"role\": \"ROLE_FREELANCER\"\n}"
            }
          }
        },
        {
          "name": "Ban User",
          "request": {
            "method": "PATCH",
            "description": "Ban a user account. Admin only.",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/ban", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "ban"] }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "description": "Activate or reactivate a user account. Admin only.",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/activate", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "activate"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        }
      ]
    },
