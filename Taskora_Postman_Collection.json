            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"E-Commerce Platform Redesign - Phase 2\",\n  \"description\": \"Phase 2: Advanced features including payment gateway and analytics dashboard.\",\n  \"budget\": 22000.00,\n  \"status\": \"TERMINE\",\n  \"startDate\": \"2026-03-01\",\n  \"endDate\": \"2026-09-30\",\n  \"clientId\": 1,\n  \"userId\": 1\n}"
            }
          }
